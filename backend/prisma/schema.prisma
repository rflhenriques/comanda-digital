generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------
// TABELAS BASE (CADASTROS)
// -------------------------------------------------

model Restaurante {
  id            String    @id @default(uuid())
  nome_fantasia String
  cnpj          String    @unique
  plano         Plano     @default(BASICO)
  status        String    @default("ATIVO")
  limite_mesas  Int       @default(10)
  criado_em     DateTime  @default(now())

  // Relacionamentos Reversos (Essencial para o Prisma)
  usuarios      Usuario[]
  categorias    Categoria[]
  produtos      Produto[]
  mesas         Mesa[]
  comandas      Comanda[]
  caixas        Caixa[]
  clientes      Cliente[]

  @@map("restaurantes")
}

enum Plano {
  BASICO
  PRO
  ENTERPRISE
}

enum Cargo {
  GARCOM
  CAIXA
  GERENTE
  COZINHA
}

model Usuario {
  id             String      @id @default(uuid())
  nome           String
  email          String      @unique
  senha_hash     String
  cargo          Cargo       @default(GARCOM)
  criado_em      DateTime    @default(now())

  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])

  caixas         Caixa[]
  movimentacoes  MovimentacaoCaixa[]

  @@map("usuarios")
}

model Cliente {
  id             String      @id @default(uuid())
  cpf            String      // Removido @unique global para permitir o mesmo CPF em restaurantes diferentes (SaaS)
  nome           String
  telefone       String?
  criado_em      DateTime    @default(now())

  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])
  
  comandas       Comanda[]

  @@unique([cpf, restaurante_id]) // CPF único POR restaurante
  @@map("clientes")
}

model Mesa {
  id             String      @id @default(uuid())
  numero         Int
  qr_code_url    String?

  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])
  comandas       Comanda[]

  @@map("mesas")
}

// -------------------------------------------------
// TABELAS DE MOVIMENTAÇÃO E CAIXA
// -------------------------------------------------

enum StatusCaixa {
  ABERTO
  FECHADO
}

model Caixa {
  id             String            @id @default(uuid())
  valor_inicial  Decimal           @db.Decimal(10, 2)
  valor_final    Decimal?          @db.Decimal(10, 2)
  status         StatusCaixa       @default(ABERTO)
  aberto_em      DateTime          @default(now())
  fechado_em     DateTime?

  restaurante_id String
  restaurante    Restaurante       @relation(fields: [restaurante_id], references: [id])

  usuario_id     String
  usuario        Usuario           @relation(fields: [usuario_id], references: [id])

  movimentacoes  MovimentacaoCaixa[]

  @@map("caixas")
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
}

model MovimentacaoCaixa {
  id         String           @id @default(uuid())
  descricao  String
  valor      Decimal          @db.Decimal(10, 2)
  tipo       TipoMovimentacao
  criado_em  DateTime         @default(now())

  caixa_id   String
  caixa      Caixa            @relation(fields: [caixa_id], references: [id])

  usuario_id String
  usuario    Usuario          @relation(fields: [usuario_id], references: [id])

  @@map("movimentacoes_caixa")
}

// -------------------------------------------------
// TABELAS DO CARDÁPIO
// -------------------------------------------------

model Categoria {
  id             String      @id @default(uuid())
  nome           String
  criado_em      DateTime    @default(now())

  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])

  produtos       Produto[]

  @@map("categorias")
}

model Produto {
  id             String        @id @default(uuid())
  nome           String
  descricao      String?
  imagem         String?       // 🚀 NOVO CAMPO DE IMAGEM ADICIONADO AQUI
  preco          Decimal       @db.Decimal(10, 2)
  ativo          Boolean       @default(true)
  criado_em      DateTime      @default(now())

  categoria_id   String
  categoria      Categoria     @relation(fields: [categoria_id], references: [id])

  restaurante_id String
  restaurante    Restaurante   @relation(fields: [restaurante_id], references: [id])

  itens          ItemComanda[]

  @@map("produtos")
}

// -------------------------------------------------
// TABELAS DE COMANDAS E PEDIDOS
// -------------------------------------------------

enum StatusComanda {
  ABERTA
  AGUARDANDO_PAGAMENTO
  PAGA
  CANCELADA
}

model Comanda {
  id             String        @id @default(uuid())
  status         StatusComanda @default(ABERTA)
  aberta_em      DateTime      @default(now())
  fechada_em     DateTime?

  restaurante_id String
  restaurante    Restaurante   @relation(fields: [restaurante_id], references: [id])

  cliente_id     String?       
  cliente        Cliente?      @relation(fields: [cliente_id], references: [id])

  mesa_id        String?
  mesa           Mesa?         @relation(fields: [mesa_id], references: [id])

  itens          ItemComanda[]

  @@map("comandas")
}

enum StatusPreparo {
  FILA
  PREPARANDO
  PRONTO
  ENTREGUE
}

model ItemComanda {
  id             String        @id @default(uuid())
  quantidade     Int           @default(1)
  observacao     String?
  status_preparo StatusPreparo @default(FILA)
  pedido_em      DateTime      @default(now())

  comanda_id     String
  comanda        Comanda       @relation(fields: [comanda_id], references: [id])

  produto_id     String
  produto        Produto       @relation(fields: [produto_id], references: [id])

  @@map("itens_comanda")
}