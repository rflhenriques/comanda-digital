generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------
// TABELAS BASE (CADASTROS)
// -------------------------------------------------

model Restaurante {
  id            String   @id @default(uuid())
  nome_fantasia String
  cnpj          String   @unique
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())

  // Relacionamentos (O que pertence ao restaurante)
  usuarios      Usuario[]
  produtos      Produto[]
  mesas         Mesa[]
  comandas      Comanda[]

  @@map("restaurantes")

  caixas Caixa[]
}

enum Cargo {
  GARCOM
  CAIXA
  GERENTE
  COZINHA
}

model Usuario {
  id             String      @id @default(uuid())
  nome           String
  email          String      @unique
  senha_hash     String
  cargo          Cargo       @default(GARCOM)
  criado_em      DateTime    @default(now())

  // Relacionamento: Este usuário trabalha em 1 restaurante
  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])

  @@map("usuarios")

  caixas Caixa[]

  movimentacoes MovimentacaoCaixa[]
}

model Cliente {
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  telefone  String?  // O "?" significa que é opcional
  criado_em DateTime @default(now())

  // Relacionamento: Um cliente pode ter várias comandas ao longo do tempo
  comandas  Comanda[]

  @@map("clientes")
}

model Produto {
  id               String      @id @default(uuid())
  nome             String
  preco            Decimal     @db.Decimal(10, 2) // Para lidar com dinheiro corretamente
  categoria        String
  controla_estoque Boolean     @default(true)
  criado_em        DateTime    @default(now())

  restaurante_id   String
  restaurante      Restaurante @relation(fields: [restaurante_id], references: [id])
  itens_comanda    ItemComanda[]

  @@map("produtos")
}

model Mesa {
  id             String      @id @default(uuid())
  numero         Int
  qr_code_url    String?
  
  restaurante_id String
  restaurante    Restaurante @relation(fields: [restaurante_id], references: [id])
  comandas       Comanda[]

  @@map("mesas")
}

// -------------------------------------------------
// TABELAS DE MOVIMENTAÇÃO (O FLUXO DE VENDA)
// -------------------------------------------------

enum StatusComanda {
  ABERTA
  AGUARDANDO_PAGAMENTO  
  PAGA
  CANCELADA
}

model Comanda {
  id             String        @id @default(uuid())
  status         StatusComanda @default(ABERTA)
  aberta_em      DateTime      @default(now())
  fechada_em     DateTime?     // Nulo até o cliente pagar

  restaurante_id String
  restaurante    Restaurante   @relation(fields: [restaurante_id], references: [id])
  
  cliente_id     String
  cliente        Cliente       @relation(fields: [cliente_id], references: [id])
  
  mesa_id        String?       // Opcional (o cliente pode estar no balcão)
  mesa           Mesa?         @relation(fields: [mesa_id], references: [id])

  itens          ItemComanda[]

  @@map("comandas")
}

enum StatusPreparo {
  FILA
  PREPARANDO
  PRONTO
  ENTREGUE
}

model ItemComanda {
  id             String        @id @default(uuid())
  quantidade     Int           @default(1)
  observacao     String?       // Ex: "Sem cebola"
  status_preparo StatusPreparo @default(FILA)
  pedido_em      DateTime      @default(now())

  comanda_id     String
  comanda        Comanda       @relation(fields: [comanda_id], references: [id])

  produto_id     String
  produto        Produto       @relation(fields: [produto_id], references: [id])

  @@map("itens_comanda")
}

enum StatusCaixa {
  ABERTO
  FECHADO
}

model Caixa {
  id              String      @id @default(uuid())
  valor_inicial   Decimal     @db.Decimal(10, 2) // Dinheiro de troco para começar o dia
  valor_final     Decimal?    @db.Decimal(10, 2) // Quanto tinha na gaveta na hora de ir embora
  status          StatusCaixa @default(ABERTO)
  aberto_em       DateTime    @default(now())
  fechado_em      DateTime?

  // Relações: Precisamos saber de qual restaurante é esse caixa e QUEM abriu ele
  restaurante_id  String
  restaurante     Restaurante @relation(fields: [restaurante_id], references: [id])
  
  usuario_id      String
  usuario         Usuario     @relation(fields: [usuario_id], references: [id])

  @@map("caixas")

  movimentacoes MovimentacaoCaixa[]
}

enum TipoMovimentacao {
  ENTRADA // Suprimento (Colocar troco)
  SAIDA   // Sangria (Pagar despesas)
}

model MovimentacaoCaixa {
  id          String           @id @default(uuid())
  descricao   String           // Ex: "Pagamento do motoboy", "Troco extra"
  valor       Decimal          @db.Decimal(10, 2)
  tipo        TipoMovimentacao
  criado_em   DateTime         @default(now())

  // Relações: Precisamos saber em qual caixa isso aconteceu e QUEM fez
  caixa_id    String
  caixa       Caixa            @relation(fields: [caixa_id], references: [id])
  
  usuario_id  String
  usuario     Usuario          @relation(fields: [usuario_id], references: [id])

  @@map("movimentacoes_caixa")
}